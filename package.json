{
  "name": "digi-scratch-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "prisma migrate deploy",
    "seed": "tsx src/seed.ts",
    "prisma:generate": "prisma generate",
    "test:auth": "tsx tests/scripts/auth/run-auth-smoke.ts",
    "test:health": "tsx tests/scripts/health/run-health-check.ts"
  },
  "keywords": [
    "express",
    "prisma",
    "railway",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "description": "Secure promotional backend for Digi Scratch",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
